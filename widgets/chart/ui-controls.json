{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show chart title/header row",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show widget background and border",
    "group": "Layout"
  },
  "showLegend": {
    "type": "boolean",
    "default": true,
    "description": "Show dataset legend",
    "group": "Layout"
  },
  "chartStyle": {
    "type": "text",
    "default": "line",
    "enum": [
      "line",
      "step",
      "area",
      "bar"
    ],
    "description": "Primary chart rendering style",
    "group": "Series"
  },
  "lineWidth": {
    "type": "number",
    "default": 2,
    "min": 1,
    "max": 8,
    "format": "range",
    "description": "Series line width",
    "group": "Series"
  },
  "pointRadius": {
    "type": "number",
    "default": 0,
    "min": 0,
    "max": 6,
    "format": "range",
    "description": "Visible point radius",
    "group": "Series"
  },
  "smoothing": {
    "type": "number",
    "default": 0.25,
    "min": 0,
    "max": 0.95,
    "step": 0.05,
    "format": "range",
    "description": "Line interpolation amount",
    "group": "Series"
  },
  "fillArea": {
    "type": "boolean",
    "default": false,
    "description": "Fill the area beneath line series",
    "group": "Series"
  },
  "channel1Label": {
    "type": "text",
    "default": "",
    "description": "Display label for channel 1",
    "group": "Series"
  },
  "channel2Label": {
    "type": "text",
    "default": "",
    "description": "Display label for channel 2",
    "group": "Series"
  },
  "channel3Label": {
    "type": "text",
    "default": "",
    "description": "Display label for channel 3",
    "group": "Series"
  },
  "channel4Label": {
    "type": "text",
    "default": "",
    "description": "Display label for channel 4",
    "group": "Series"
  },
  "channel1Color": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Override channel 1 color",
    "group": "Series"
  },
  "channel2Color": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Override channel 2 color",
    "group": "Series"
  },
  "channel3Color": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Override channel 3 color",
    "group": "Series"
  },
  "channel4Color": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Override channel 4 color",
    "group": "Series"
  },
  "timeRangePreset": {
    "type": "text",
    "default": "5m",
    "enum": [
      "4s",
      "15s",
      "30s",
      "1m",
      "5m",
      "15m",
      "1h",
      "6h",
      "24h",
      "7d",
      "custom"
    ],
    "description": "History window shown by default",
    "group": "Time"
  },
  "customSpanSeconds": {
    "type": "number",
    "default": 300,
    "min": 4,
    "max": 604800,
    "description": "Window length in seconds when timeRangePreset is custom",
    "group": "Time"
  },
  "maxPoints": {
    "type": "number",
    "default": 1000,
    "min": 100,
    "max": 5000,
    "step": 50,
    "description": "Maximum historical samples fetched per channel",
    "group": "Time"
  },
  "showGrid": {
    "type": "boolean",
    "default": true,
    "description": "Show chart grid lines",
    "group": "Axes"
  },
  "showAxes": {
    "type": "boolean",
    "default": true,
    "description": "Show axis lines and tick labels",
    "group": "Axes"
  },
  "showTooltip": {
    "type": "boolean",
    "default": true,
    "description": "Show hover tooltip",
    "group": "Axes"
  },
  "rightAxisEnabled": {
    "type": "boolean",
    "default": true,
    "description": "Enable right-side Y-axis for alternating channels",
    "group": "Axes"
  },
  "leftAxisLabel": {
    "type": "text",
    "default": "",
    "description": "Left axis label",
    "group": "Axes"
  },
  "rightAxisLabel": {
    "type": "text",
    "default": "",
    "description": "Right axis label",
    "group": "Axes"
  },
  "axisColor": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Axis and tick color override",
    "group": "Appearance"
  },
  "legendColor": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Legend text color override",
    "group": "Appearance"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Header background override",
    "group": "Appearance"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Widget background override",
    "group": "Appearance"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "format": "color",
    "description": "Widget border color override",
    "group": "Appearance"
  },
  "oscilloscopeMode": {
    "type": "boolean",
    "default": false,
    "description": "Enable CRT oscilloscope rendering mode",
    "group": "Oscilloscope"
  },
  "oscilloscopeColor": {
    "type": "text",
    "default": "#66FF99",
    "format": "color",
    "description": "Primary phosphor line color",
    "group": "Oscilloscope"
  },
  "oscilloscopeGlow": {
    "type": "number",
    "default": 16,
    "min": 0,
    "max": 40,
    "format": "range",
    "description": "Line glow radius",
    "group": "Oscilloscope"
  },
  "oscilloscopeScanlineOpacity": {
    "type": "number",
    "default": 0.12,
    "min": 0,
    "max": 0.35,
    "step": 0.01,
    "format": "range",
    "description": "Scanline overlay opacity",
    "group": "Oscilloscope"
  },
  "oscilloscopePersistence": {
    "type": "number",
    "default": 0.22,
    "min": 0,
    "max": 0.95,
    "step": 0.01,
    "format": "range",
    "description": "Phosphor persistence trail amount",
    "group": "Oscilloscope"
  },
  "oscilloscopeNoise": {
    "type": "number",
    "default": 0.03,
    "min": 0,
    "max": 0.2,
    "step": 0.01,
    "format": "range",
    "description": "CRT noise grain intensity",
    "group": "Oscilloscope"
  }
}