{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show toggle control",
    "group": "Layout"
  },
  "showToggleLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show ON/OFF text beside toggle",
    "group": "Layout"
  },
  "showActiveIndicator": {
    "type": "boolean",
    "default": true,
    "description": "Show Active Low / Active High indicator",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "onLabel": { "type": "text", "default": "ON", "group": "Toggle", "description": "Toggle text when on" },
  "offLabel": { "type": "text", "default": "OFF", "group": "Toggle", "description": "Toggle text when off" },
  "toggleOnColor": { "type": "text", "default": "", "group": "Toggle", "description": "Toggle track color when on", "format": "color-alpha", "x-theme-default": "accentGreen" },
  "toggleOffColor": { "type": "text", "default": "", "group": "Toggle", "description": "Toggle track color when off", "format": "color-alpha", "x-theme-default": "bgTertiary" },
  "toggleTextColor": { "type": "text", "default": "", "group": "Toggle", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Toggle label text color" },
  "toggleFontFamily": { "type": "text", "default": "", "group": "Toggle", "format": "font-family", "description": "Toggle label font family" },
  "toggleFontSize": { "type": "number", "default": 19, "group": "Toggle", "format": "font-size", "min": 10, "max": 120, "description": "Toggle label font size" },
  "toggleFontWeight": { "type": "text", "default": "700", "group": "Toggle", "format": "font-weight", "description": "Toggle label font weight" },
  "toggleFontStyle": { "type": "text", "default": "normal", "group": "Toggle", "format": "font-style", "description": "Toggle label font style" }
}
