{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "showFooter": {
    "type": "boolean",
    "default": true,
    "description": "Show footer controls",
    "group": "Layout"
  },
  "precision": {
    "type": "number",
    "default": 2,
    "min": 0,
    "max": 6,
    "description": "Decimal places for value display",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "showCurrent": { "type": "boolean", "default": true, "group": "Current", "description": "Show the current value section" },
  "currentColor": { "type": "text", "default": "", "group": "Current", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Current value text color" },
  "currentBg": { "type": "text", "default": "", "group": "Current", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Current value box background" },
  "currentLabelColor": { "type": "text", "default": "", "group": "Current", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Current value label color" },
  "currentFont": { "type": "text", "default": "", "group": "Current", "format": "font-family", "description": "Current value font family" },
  "currentSize": { "type": "number", "default": null, "group": "Current", "format": "font-size", "min": 8, "max": 120, "description": "Current value font size in px" },
  "currentWeight": { "type": "text", "default": "", "group": "Current", "format": "font-weight", "description": "Current value font weight" },
  "currentStyle": { "type": "text", "default": "", "group": "Current", "format": "font-style", "description": "Current value font style" },
  "showRequested": { "type": "boolean", "default": true, "group": "Requested", "description": "Show the requested value section" },
  "requestedColor": { "type": "text", "default": "", "group": "Requested", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Requested value text color" },
  "requestedBg": { "type": "text", "default": "", "group": "Requested", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Requested value box background" },
  "requestedLabelColor": { "type": "text", "default": "", "group": "Requested", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Requested value label color" },
  "requestedFont": { "type": "text", "default": "", "group": "Requested", "format": "font-family", "description": "Requested value font family" },
  "requestedSize": { "type": "number", "default": null, "group": "Requested", "format": "font-size", "min": 8, "max": 120, "description": "Requested value font size in px" },
  "requestedWeight": { "type": "text", "default": "", "group": "Requested", "format": "font-weight", "description": "Requested value font weight" },
  "requestedStyle": { "type": "text", "default": "", "group": "Requested", "format": "font-style", "description": "Requested value font style" }
}
