{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show toggle control",
    "group": "Layout"
  },
  "showToggleLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show ON/OFF text beside toggle",
    "group": "Layout"
  },
  "onLabel": {
    "type": "text",
    "default": "ON",
    "group": "Toggle",
    "description": "Toggle text when true"
  },
  "offLabel": {
    "type": "text",
    "default": "OFF",
    "group": "Toggle",
    "description": "Toggle text when false"
  },
  "toggleOnColor": {
    "type": "text",
    "default": "",
    "group": "Toggle",
    "description": "Toggle track color when on",
    "format": "color-alpha",
    "x-theme-default": "accentGreen"
  },
  "toggleOffColor": {
    "type": "text",
    "default": "",
    "group": "Toggle",
    "description": "Toggle track color when off",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "valueFontFamily": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "font-family"
  },
  "valueFontSize": {
    "type": "number",
    "default": 19,
    "group": "Value",
    "format": "font-size",
    "min": 10,
    "max": 120
  },
  "valueFontWeight": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "font-weight"
  },
  "valueFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Value",
    "format": "font-style"
  },
  "valueColor": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "color-alpha",
    "x-theme-default": "accentGreen"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  }
}