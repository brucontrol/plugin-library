{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showFooter": {
    "type": "boolean",
    "default": true,
    "description": "Show footer bar",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "buttonColor": {
    "type": "text",
    "default": "",
    "group": "Footer",
    "description": "Override Activate/Deactivate button background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "showActive": { "type": "boolean", "default": true, "group": "Active", "description": "Show the Active section" },
  "activeColor": { "type": "text", "default": "", "group": "Active", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Active value text color" },
  "activeBg": { "type": "text", "default": "", "group": "Active", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Active box background" },
  "activeLabelColor": { "type": "text", "default": "", "group": "Active", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Active label text color" },
  "activeFont": { "type": "text", "default": "", "group": "Active", "format": "font-family" },
  "activeSize": { "type": "number", "default": null, "group": "Active", "format": "font-size", "min": 8, "max": 120 },
  "activeWeight": { "type": "text", "default": "", "group": "Active", "format": "font-weight" },
  "activeStyle": { "type": "text", "default": "", "group": "Active", "format": "font-style" },
  "showSound": { "type": "boolean", "default": true, "group": "Sound", "description": "Show the Sound section" },
  "soundColor": { "type": "text", "default": "", "group": "Sound", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Sound value text color" },
  "soundLabelColor": { "type": "text", "default": "", "group": "Sound", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Sound label text color" },
  "soundFont": { "type": "text", "default": "", "group": "Sound", "format": "font-family" },
  "soundSize": { "type": "number", "default": null, "group": "Sound", "format": "font-size", "min": 8, "max": 120 },
  "soundWeight": { "type": "text", "default": "", "group": "Sound", "format": "font-weight" },
  "soundStyle": { "type": "text", "default": "", "group": "Sound", "format": "font-style" }
}
