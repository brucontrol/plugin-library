{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": false,
    "description": "Show numeric value in dial center",
    "group": "Layout"
  },
  "selectOptions": {
    "type": "array",
    "description": "Numeric values to place around the dial",
    "group": "Options",
    "default": [
      0,
      25,
      50,
      75,
      100
    ],
    "items": {
      "type": "number"
    }
  },
  "dialColor": {
    "type": "text",
    "default": "",
    "group": "Dial",
    "description": "Dial face color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "needleColor": {
    "type": "text",
    "default": "",
    "group": "Dial",
    "description": "Indicator needle color",
    "format": "color-alpha",
    "x-theme-default": "accentGreen"
  },
  "activeColor": {
    "type": "text",
    "default": "",
    "group": "Dial",
    "description": "Highlight color for selected value",
    "format": "color-alpha",
    "x-theme-default": "accentPrimary"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "displayColor": {
    "type": "text",
    "default": "",
    "group": "Display",
    "format": "color-alpha",
    "x-theme-default": "accentGreen",
    "description": "Value display text color"
  },
  "displayFontFamily": {
    "type": "text",
    "default": "",
    "group": "Display",
    "format": "font-family",
    "description": "Value display font family"
  },
  "displayFontSize": {
    "type": "number",
    "default": 26,
    "group": "Display",
    "format": "font-size",
    "min": 10,
    "max": 120,
    "description": "Value display font size"
  },
  "displayFontWeight": {
    "type": "text",
    "default": "",
    "group": "Display",
    "format": "font-weight",
    "description": "Value display font weight"
  },
  "displayFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Display",
    "format": "font-style",
    "description": "Value display font style"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  }
}