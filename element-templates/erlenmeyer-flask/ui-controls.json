{
  "value": {
    "type": "number",
    "title": "Value",
    "default": 50,
    "min": 0,
    "max": 100,
    "description": "Current liquid level (0-100%)"
  },
  "min": {
    "type": "number",
    "title": "Minimum",
    "default": 0,
    "description": "Minimum of the range"
  },
  "max": {
    "type": "number",
    "title": "Maximum",
    "default": 100,
    "description": "Maximum of the range"
  },
  "liquidColor": {
    "type": "text",
    "title": "Liquid Color",
    "default": "#3b82f6",
    "format": "color-alpha",
    "description": "Hex color for the liquid"
  },
  "levelTransitionMs": {
    "type": "number",
    "title": "Level Transition (ms)",
    "default": 500,
    "min": 100,
    "max": 3000,
    "step": 50,
    "description": "Duration for liquid level rise/fall animation"
  },
  "bubbleDurationMs": {
    "type": "number",
    "title": "Bubble Speed (ms)",
    "default": 3000,
    "min": 1000,
    "max": 8000,
    "step": 100,
    "description": "Duration for one bubble float cycle"
  },
  "bubbleDensity": {
    "type": "number",
    "title": "Bubble Density",
    "default": 8,
    "min": 0,
    "max": 20,
    "step": 1,
    "description": "Number of bubbles visible"
  },
  "stirEnabled": {
    "type": "boolean",
    "title": "Stir Effect",
    "default": false,
    "description": "Enable spinning vortex effect (like a stir plate)"
  },
  "stirSpeedMs": {
    "type": "number",
    "title": "Stir Speed (ms per rotation)",
    "default": 4000,
    "min": 1000,
    "max": 10000,
    "step": 500,
    "description": "Time for one full rotation of the stir effect"
  }
}
