{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "showSecondaryRows": {
    "type": "boolean",
    "default": true,
    "description": "Show secondary detail rows",
    "group": "Layout"
  },
  "showFooter": {
    "type": "boolean",
    "default": true,
    "description": "Show footer controls",
    "group": "Layout"
  },
  "precision": {
    "type": "number",
    "default": 2,
    "min": 0,
    "max": 6,
    "description": "Decimal places for numeric displays",
    "group": "Layout"
  },
  "footerButtonColor": {
    "type": "text",
    "default": "",
    "group": "Footer",
    "format": "color-alpha",
    "x-theme-default": "accentPrimary",
    "description": "Set Target button background color"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
