  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "valueFontFamily": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "font-family"
  },
  "valueFontSize": {
    "type": "number",
    "default": 14,
    "group": "Value",
    "format": "font-size",
    "min": 10,
    "max": 120
  },
  "valueFontWeight": {
    "type": "text",
    "default": "700",
    "group": "Value",
    "format": "font-weight"
  },
  "valueFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Value",
    "format": "font-style"
  },
  "valueColor": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "color-alpha",
    "x-theme-default": "accentGreen",
    "description": "Default value text color for all primary rows"
  },
  "valueBackgroundColor": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary",
    "description": "Default background color for all primary value rows"
  },
  "precision": {
    "type": "number",
    "default": 2,
    "min": 0,
    "max": 6,
    "description": "Decimal places for value display",
    "group": "Value"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "rowLabelColor": {
    "type": "text",
    "default": "",
    "group": "Rows",
    "description": "Default label color for all rows",
    "format": "color-alpha",
