  "bandColor": { "type": "text", "default": "", "group": "Band", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Band value text color" },
  "bandLabelColor": { "type": "text", "default": "", "group": "Band", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Band label text color" },
