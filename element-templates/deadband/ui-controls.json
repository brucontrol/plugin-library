{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "showSecondaryRows": {
    "type": "boolean",
    "default": true,
    "description": "Show secondary detail rows",
    "group": "Layout"
  },
  "showFooter": {
    "type": "boolean",
    "default": true,
    "description": "Show footer controls",
    "group": "Layout"
  },
  "footerButtonColor": {
    "type": "text",
    "default": "",
    "group": "Footer",
    "format": "color-alpha",
    "x-theme-default": "accentPrimary",
    "description": "Set Target button background color"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
