{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "showSecondaryRows": {
    "type": "boolean",
    "default": true,
    "description": "Show secondary detail rows",
    "group": "Layout"
  },
  "showFooter": {
    "type": "boolean",
    "default": false,
    "description": "Show footer controls (unused when value is clickable)",
    "group": "Layout"
  },
  "precision": {
    "type": "number",
    "default": 1,
    "min": 0,
    "max": 6,
    "description": "Decimal places for duty and interval",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "showDuty": { "type": "boolean", "default": true, "group": "Duty", "description": "Show the Duty section" },
  "dutyColor": { "type": "text", "default": "", "group": "Duty", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Duty value text color" },
  "dutyBg": { "type": "text", "default": "", "group": "Duty", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Duty box background color" },
  "dutyLabelColor": { "type": "text", "default": "", "group": "Duty", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Duty label text color" },
  "dutyFont": { "type": "text", "default": "", "group": "Duty", "format": "font-family", "description": "Duty value font family" },
  "dutySize": { "type": "number", "default": null, "group": "Duty", "format": "font-size", "min": 8, "max": 120, "description": "Duty value font size in px" },
  "dutyWeight": { "type": "text", "default": "", "group": "Duty", "format": "font-weight", "description": "Duty value font weight" },
  "dutyStyle": { "type": "text", "default": "", "group": "Duty", "format": "font-style", "description": "Duty value font style" },
  "showInterval": { "type": "boolean", "default": true, "group": "Interval", "description": "Show the Interval section" },
  "intervalColor": { "type": "text", "default": "", "group": "Interval", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Interval value text color" },
  "intervalLabelColor": { "type": "text", "default": "", "group": "Interval", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Interval label text color" },
  "intervalFont": { "type": "text", "default": "", "group": "Interval", "format": "font-family", "description": "Interval value font family" },
  "intervalSize": { "type": "number", "default": null, "group": "Interval", "format": "font-size", "min": 8, "max": 120, "description": "Interval value font size in px" },
  "intervalWeight": { "type": "text", "default": "", "group": "Interval", "format": "font-weight", "description": "Interval value font weight" },
  "intervalStyle": { "type": "text", "default": "", "group": "Interval", "format": "font-style", "description": "Interval value font style" }
}
