{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "showSecondaryRows": {
    "type": "boolean",
    "default": true,
    "description": "Show secondary detail rows",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "showCount": { "type": "boolean", "default": true, "group": "Count", "description": "Show the Count section" },
  "countLabel": { "type": "text", "default": "Count", "group": "Count", "description": "Label for the count value (e.g. Count, Total)" },
  "countPrecision": { "type": "number", "default": 0, "group": "Count", "description": "Decimal places for count display", "min": 0, "max": 6 },
  "countColor": { "type": "text", "default": "", "group": "Count", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Count value text color" },
  "countBg": { "type": "text", "default": "", "group": "Count", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Count box background color" },
  "countLabelColor": { "type": "text", "default": "", "group": "Count", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Count label text color" },
  "countFont": { "type": "text", "default": "", "group": "Count", "format": "font-family", "description": "Count value font family" },
  "countSize": { "type": "number", "default": null, "group": "Count", "format": "font-size", "min": 8, "max": 120, "description": "Count value font size in px" },
  "countWeight": { "type": "text", "default": "", "group": "Count", "format": "font-weight", "description": "Count value font weight" },
  "countStyle": { "type": "text", "default": "", "group": "Count", "format": "font-style", "description": "Count value font style" },
  "countLabelFontFamily": { "type": "text", "default": "", "group": "Count", "format": "font-family", "description": "Count label font family" },
  "countLabelFontSize": { "type": "number", "default": 10, "group": "Count", "format": "font-size", "min": 8, "max": 24, "description": "Count label font size" },
  "countLabelFontWeight": { "type": "text", "default": "", "group": "Count", "format": "font-weight", "description": "Count label font weight" },
  "countLabelFontStyle": { "type": "text", "default": "normal", "group": "Count", "format": "font-style", "description": "Count label font style" },
  "showRate": { "type": "boolean", "default": true, "group": "Rate", "description": "Show the Rate section" },
  "ratePrecision": { "type": "number", "default": 2, "group": "Rate", "description": "Decimal places for rate display", "min": 0, "max": 6 },
  "rateColor": { "type": "text", "default": "", "group": "Rate", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Rate value text color" },
  "rateLabelColor": { "type": "text", "default": "", "group": "Rate", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Rate label text color" },
  "rateFont": { "type": "text", "default": "", "group": "Rate", "format": "font-family", "description": "Rate value font family" },
  "rateSize": { "type": "number", "default": null, "group": "Rate", "format": "font-size", "min": 8, "max": 120, "description": "Rate value font size in px" },
  "rateWeight": { "type": "text", "default": "", "group": "Rate", "format": "font-weight", "description": "Rate value font weight" },
  "rateStyle": { "type": "text", "default": "", "group": "Rate", "format": "font-style", "description": "Rate value font style" }
}
