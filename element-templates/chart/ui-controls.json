{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show chart title/header row",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLegend": {
    "type": "boolean",
    "default": true,
    "description": "Show dataset legend",
    "group": "Layout"
  },
  "chartStyle": {
    "type": "text",
    "default": "line",
    "enum": [
      "line",
      "area",
      "bar"
    ],
    "description": "Primary chart rendering style",
    "group": "Series"
  },
  "lineWidth": {
    "type": "number",
    "default": 2,
    "min": 1,
    "max": 8,
    "format": "range",
    "description": "Series line width",
    "group": "Series"
  },
  "pointRadius": {
    "type": "number",
    "default": 0,
    "min": 0,
    "max": 6,
    "format": "range",
    "description": "Visible point radius",
    "group": "Series"
  },
  "smoothing": {
    "type": "number",
    "default": 0.25,
    "min": 0,
    "max": 0.95,
    "step": 0.05,
    "format": "range",
    "description": "Line interpolation amount",
    "group": "Series"
  },
  "fillArea": {
    "type": "boolean",
