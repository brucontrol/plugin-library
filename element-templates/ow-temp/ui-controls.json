{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show primary value rows",
    "group": "Layout"
  },
  "decimalPlaces": {
    "type": "number",
    "default": 1,
    "min": 0,
    "max": 5,
    "description": "Number of decimal places for temperature",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "500",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  },
  "showTemperature": { "type": "boolean", "default": true, "group": "Temperature", "description": "Show the Temperature section" },
  "temperatureColor": { "type": "text", "default": "", "group": "Temperature", "format": "color-alpha", "x-theme-default": "accentGreen", "description": "Temperature value text color" },
  "temperatureBg": { "type": "text", "default": "", "group": "Temperature", "format": "color-alpha", "x-theme-default": "bgTertiary", "description": "Temperature box background color" },
  "temperatureLabelColor": { "type": "text", "default": "", "group": "Temperature", "format": "color-alpha", "x-theme-default": "textSecondary", "description": "Temperature label text color" },
  "temperatureFont": { "type": "text", "default": "", "group": "Temperature", "format": "font-family", "description": "Temperature value font family" },
  "temperatureSize": { "type": "number", "default": null, "group": "Temperature", "format": "font-size", "min": 8, "max": 120, "description": "Temperature value font size in px" },
  "temperatureWeight": { "type": "text", "default": "", "group": "Temperature", "format": "font-weight", "description": "Temperature value font weight" },
  "temperatureStyle": { "type": "text", "default": "", "group": "Temperature", "format": "font-style", "description": "Temperature value font style" }
}
