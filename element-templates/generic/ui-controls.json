{
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show value text",
    "group": "Layout"
  },
  "valueFontFamily": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "font-family"
  },
  "valueFontSize": {
    "type": "number",
    "default": 14,
    "group": "Value",
    "format": "font-size",
    "min": 10,
    "max": 120
  },
  "valueColor": {
    "type": "text",
    "default": "",
    "group": "Value",
    "format": "color-alpha",
    "x-theme-default": "accentGreen"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  }
}
