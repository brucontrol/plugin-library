{
  "showHeader": {
    "type": "boolean",
    "default": true,
    "description": "Show header bar",
    "group": "Layout"
  },
  "showLabel": {
    "type": "boolean",
    "default": true,
    "description": "Show title label in header",
    "group": "Layout"
  },
  "showBackground": {
    "type": "boolean",
    "default": true,
    "description": "Show element background and border",
    "group": "Layout"
  },
  "showValue": {
    "type": "boolean",
    "default": true,
    "description": "Show value text",
    "group": "Layout"
  },
  "labelFontFamily": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-family"
  },
  "labelFontSize": {
    "type": "number",
    "default": 12,
    "group": "Label",
    "format": "font-size",
    "min": 8,
    "max": 48
  },
  "labelFontWeight": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "font-weight"
  },
  "labelFontStyle": {
    "type": "text",
    "default": "normal",
    "group": "Label",
    "format": "font-style"
  },
  "labelColor": {
    "type": "text",
    "default": "",
    "group": "Label",
    "format": "color-alpha",
    "x-theme-default": "textPrimary"
  },
  "displayColor": {
    "type": "text",
    "default": "",
    "group": "Display",
    "format": "color-alpha",
    "x-theme-default": "accentGreen",
    "description": "Property value text color"
  },
  "displayFontFamily": {
    "type": "text",
    "default": "",
    "group": "Display",
    "format": "font-family",
    "description": "Property value font family"
  },
  "displayFontSize": {
    "type": "number",
    "default": 14,
    "group": "Display",
    "format": "font-size",
    "min": 8,
    "max": 120,
    "description": "Property value font size"
  },
  "headerColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override header background color",
    "format": "color-alpha",
    "x-theme-default": "bgTertiary"
  },
  "backgroundColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override element background color",
    "format": "color-alpha",
    "x-theme-default": "bgSecondary"
  },
  "borderColor": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Override border color",
    "format": "color-alpha",
    "x-theme-default": "borderColor"
  },
  "image": {
    "type": "text",
    "default": "",
    "group": "Background & Border",
    "description": "Use an image as the card background instead of color/border. When set, background, header, and border are replaced by this image.",
    "format": "file-upload",
    "title": "Background Image",
    "x-accept": "image/*,.png,.jpg,.jpeg,.gif,.webp,.svg,.bmp,.ico,.avif",
    "x-picker-title": "Select Background Image"
  }
